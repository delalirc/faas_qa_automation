# FAAS QA Automation Environment Variables

# Base URL for API testing
BASE_URL=

# Authentication
AUTH_TOKEN=

# CircleCI API Token (for triggering tests from service pipelines)
CIRCLECI_API_TOKEN=your-circleci-api-token-here

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# QA Dashboard API (optional)
QA_DASHBOARD_API=https://your-dashboard-api.com

# Cognito Authentication (optional, alternative to AUTH_TOKEN)
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id
COGNITO_REGION=af-south-1
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=your-password

# Test Data
TEST_PARTNER_ID=30f50c8b-7b88-49c1-8b61-ca93b8f6ea7f
TEST_MERCHANT_ID=your-test-merchant-id

# CI Environment
CI=false
